# dyventory-web/Dockerfile.dev
FROM node:20-alpine
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install deps first (cached layer)
COPY package.json package-lock.json* ./
RUN npm ci

# Don't copy source — it's mounted as a volume
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["npm", "run", "dev"]