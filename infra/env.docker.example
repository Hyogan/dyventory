# ══════════════════════════════════════════════════════════════════════════════
# .env.docker.example — Stoky Docker Compose environment
#
# HOW TO USE:
#   cp .env.docker.example .env.docker
#   # Edit .env.docker with your values
#   docker compose --env-file .env.docker up -d
#
# ⚠️  Never commit .env.docker — it contains secrets.
#     Only commit this .env.docker.example file.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL container ───────────────────────────────────────────────────────
POSTGRES_DB=stoky
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production

# ── Laravel API ────────────────────────────────────────────────────────────────
APP_NAME=Stoky
APP_ENV=local
APP_KEY=                            # Run: php artisan key:generate --show
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Database — points to the 'db' Docker service
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# Redis — points to the 'redis' Docker service
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache / Queue / Session — all use Redis in Docker
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Sanctum — list the frontend origins that receive cookies
# For local dev: localhost:3000
# For production: your real domain (no http://)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# Mail (use Mailpit in Docker for local testing)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@stoky.app
MAIL_FROM_NAME="${APP_NAME}"

# Horizon queue worker prefix
HORIZON_PREFIX=stoky_horizon:

# Business defaults
DEFAULT_VAT_RATE=19.25
DEFAULT_CURRENCY=XAF
STOCK_ALERT_DEFAULT_THRESHOLD=5
EXPIRY_ALERT_DAYS=7

# ── Next.js 16 Frontend ────────────────────────────────────────────────────────

# Server-side only — used in SSR fetch calls (internal Docker network)
# Points to the 'nginx' service that proxies to the 'api' PHP-FPM service
API_INTERNAL_URL=http://nginx

# Client-side (baked into the browser bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Stoky

# Set to 'true' when building the production Docker image (Dockerfile.web)
# This enables output: 'standalone' in next.config.ts
BUILD_STANDALONE=false

# Optional: used in next.config.ts remotePatterns for production image URLs
API_HOSTNAME=api.stoky.app
